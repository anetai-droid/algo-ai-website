# このファイルをコピーして .env を作成し、実値を設定してください。
#   cp .env.example .env
# .env は .gitignore 済みなので GitHub には公開されません。

# 本番の公開URL（末尾スラッシュなし）。canonical / OGP / sitemap に使用。
SITE_URL=https://algo-ai.jp

# Google Analytics 4 測定ID（例: G-XXXXXXXXXX）。未設定ならGAタグは出力されません。
VITE_GA4_ID=

# Hotjar サイトID（数値）。未設定ならHotjarタグは出力されません。
VITE_HOTJAR_ID=

# LINE公式アカウントの友だち追加URL。未設定ならLINE導線は非表示になります。
VITE_LINE_URL=

# 無料相談の予約URL（Calendly / Googleカレンダー等）。未設定なら予約ボタンは非表示。
VITE_BOOKING_URL=

# 電話番号（例: 03-1234-5678）。未設定なら電話導線は非表示。確定後に設定。
VITE_TEL=

# お問い合わせフォームの送信先エンドポイント。
# レンタルサーバーのPHPフォームを使う場合は /api/contact.php のまま。
# 外部フォームサービスを使う場合はそのURLに変更。
VITE_CONTACT_ENDPOINT=/api/contact.php
